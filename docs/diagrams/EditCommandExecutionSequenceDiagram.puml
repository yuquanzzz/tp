@startuml
!include style.puml
skinparam ArrowFontStyle plain

box Logic LOGIC_COLOR_T1
participant ":LogicManager" as LogicManager LOGIC_COLOR
participant "c:EditPersonCommand" as EditPersonCommand LOGIC_COLOR
participant ":PersonBuilder" as PersonBuilder LOGIC_COLOR
participant "r:CommandResult" as CommandResult LOGIC_COLOR
end box

box Model MODEL_COLOR_T1
participant "m:Model" as Model MODEL_COLOR
participant ":AddressBook" as AddressBook MODEL_COLOR
end box

box Storage STORAGE_COLOR_T1
participant ":Storage" as Storage STORAGE_COLOR
end box

[-> LogicManager : execute("edit student 1 p/98765432")
activate LogicManager

LogicManager -> EditPersonCommand : execute(m)
activate EditPersonCommand

EditPersonCommand -> Model : getFilteredPersonList()
activate Model
Model --> EditPersonCommand : displayed students
deactivate Model

create PersonBuilder
EditPersonCommand -> PersonBuilder : PersonBuilder(personToEdit)
activate PersonBuilder

EditPersonCommand -> PersonBuilder : withPhone(98765432)
EditPersonCommand -> PersonBuilder : build()
PersonBuilder --> EditPersonCommand : editedPerson
deactivate PersonBuilder

EditPersonCommand -> Model : hasPerson(editedPerson)
activate Model
Model --> EditPersonCommand : false
deactivate Model

EditPersonCommand -> Model : setPerson(personToEdit, editedPerson)
activate Model
Model -> AddressBook : setPerson(personToEdit, editedPerson)
activate AddressBook
AddressBook --> Model
deactivate AddressBook
Model --> EditPersonCommand
deactivate Model

create CommandResult
EditPersonCommand -> CommandResult : CommandResult(...)
activate CommandResult
CommandResult --> EditPersonCommand : r
deactivate CommandResult

EditPersonCommand --> LogicManager : r
deactivate EditPersonCommand

LogicManager -> Model : getAddressBook()
activate Model
Model --> LogicManager : updated address book
deactivate Model

LogicManager -> Storage : saveAddressBook(...)
activate Storage
Storage --> LogicManager
deactivate Storage

[<-- LogicManager
deactivate LogicManager
@enduml
